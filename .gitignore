# ignore everything at repository root by default
/*

# allow tracking of these important files/directories
!/.gitignore
!/.vscode/
!/.vscode/extensions.json
!/config.toml

# explicit project directories we want committed
!/image_rename/
!/sitemap/
!/press_release_no_nav/
!/xml_edit/
!/program_update/
# add further `!/foldername/` lines for any new toplevel folder you want tracked

# patterns to ignore anywhere in the tree
*.env
*.csv
*.log
*.txt
*.json
*.xml
__pycache__/

# other common top-level ignores
/.venv
/.github
